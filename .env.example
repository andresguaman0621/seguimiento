# === Base de datos (Turso / libSQL) ===
# Para Turso real:
#   TURSO_DATABASE_URL=libsql://<tu-db>-<org>.turso.io
#   TURSO_AUTH_TOKEN=<token generado con: turso db tokens create <tu-db>>
#
# Para prueba local sin Turso (archivo SQLite/libSQL local):
#   TURSO_DATABASE_URL=file:local.db
#   TURSO_AUTH_TOKEN=
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# === Autenticación (JWT) ===
# Cambiar por un valor largo y aleatorio en producción.
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXP_HOURS=8

# === Flask ===
FLASK_DEBUG=1
SECRET_KEY=cambia-esto-tambien
